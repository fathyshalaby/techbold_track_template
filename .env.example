# Copy to .env and fill in. NEVER commit .env or your SSH keys.
# Default is mock mode: a fresh clone boots fully offline with no credentials.

# Phoenix ERP
PHOENIX_API_BASE_URL=http://68.210.101.85:8000
PHOENIX_API_TOKEN=your-phoenix-token-here

# SSH (one *.pem per VM; the executor tries each key in the dir until one auths)
SSH_PRIVATE_KEY_DIR=/keys
SSH_USERNAME=azureuser

# LLM provider: openai | gateway | azure | openai-compatible | local
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
OPENAI_API_KEY=your-openai-key-here
AI_GATEWAY_API_KEY=
# AZURE_ENDPOINT=
# AZURE_API_KEY=
# AZURE_DEPLOYMENT=
# LLM_BASE_URL=

# Mock mode (any flag true => that service runs offline)
MOCK_MODE=true
MOCK_PHOENIX=false
MOCK_SSH=false
MOCK_LLM=false
MOCK_SCENARIOS=true
SANDBOX_PROVISIONER_ENABLED=true

# RAG memory (Postgres + pgvector; Docker sets DATABASE_URL automatically)
DATABASE_URL=postgresql://autopilot:autopilot@localhost:5432/autopilot
GEMINI_API_KEY=your-gemini-key-here

# Server
PORT=8000
NEXT_PUBLIC_API_BASE=http://localhost:8000
