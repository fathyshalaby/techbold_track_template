# Copy to .env and fill in. NEVER commit .env or your SSH key.

# ---- Phoenix ERP mock (token from Builder Base; URL is the live mock) ----
PHOENIX_API_BASE_URL=http://68.210.101.85:8000
PHOENIX_API_TOKEN=your-phoenix-token-here

# ---- SSH access to the customer VMs ----
# Provide EITHER a single key (SSH_PRIVATE_KEY_PATH) OR a directory of candidate
# keys (SSH_PRIVATE_KEY_DIR). Use the directory when each VM has its own keypair:
# the executor tries every *.pem in it until one authenticates (no hardcoded
# host->key mapping). The repo's docker-compose mounts ./keys to /keys.
SSH_PRIVATE_KEY_PATH=/keys/your-key.pem
# SSH_PRIVATE_KEY_DIR=/keys
SSH_USERNAME=azureuser

# ---- LLM (bring-your-own; the AI SDK's OpenAI provider reads OPENAI_API_KEY) ----
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
OPENAI_API_KEY=your-openai-key-here
# Vercel AI Gateway (recommended for multi-model routing): set LLM_PROVIDER=gateway and:
#   AI_GATEWAY_API_KEY=your-ai-gateway-key
# Model ids use gateway slugs, e.g. openai/gpt-4o, anthropic/claude-sonnet-4
# Create a key at https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=
# Azure AI Foundry: set LLM_PROVIDER=azure (or just set AZURE_ENDPOINT) and:
#   AZURE_ENDPOINT=https://<project>.services.ai.azure.com
#   AZURE_API_KEY=your-azure-key
#   AZURE_DEPLOYMENT=<your-deployment-name>
# Any OpenAI-compatible endpoint (OpenRouter / local): LLM_PROVIDER=openai-compatible and:
#   LLM_BASE_URL=https://openrouter.ai/api/v1   (OPENAI_API_KEY holds that endpoint's key)
# Local server example (Mac MLX trained adapter):
#   LLM_PROVIDER=local LLM_BASE_URL=http://127.0.0.1:8011/v1 LLM_MODEL=mlx-community/Qwen2.5-1.5B-Instruct-4bit
# Localhost endpoints do not require a real OPENAI_API_KEY; remote compatible endpoints still do.

# Trained MLX adapter on Mac (Apple Silicon). Train once, then serve on :8011.
# CUSTOM_MODEL_BASE_URL=http://127.0.0.1:8011/v1
# CUSTOM_MODEL_SERVED_ID=mlx-community/Qwen2.5-1.5B-Instruct-4bit

# ---- Mock mode (any flag true => that service runs offline; required creds relax) ----
# Default TRUE so a fresh `cp .env.example .env && docker compose up` boots offline
# with no real creds and never accidentally hits the live ERP with a placeholder
# token. Flip to false (and fill creds above) for real Phoenix/SSH/LLM runs.
MOCK_MODE=true
MOCK_PHOENIX=false
MOCK_SSH=false
MOCK_LLM=false
# Serve the realistic sandbox incident catalog (5 scenarios) in the offline demo
# instead of the generic 4-ticket fixtures. Only applies when Phoenix is mocked.
MOCK_SCENARIOS=true
# Dashboard VM generation (docker build/run on host). Works in live or mock mode.
SANDBOX_PROVISIONER_ENABLED=true

# ---- RAG memory (Postgres + pgvector) ----
# Docker Compose sets DATABASE_URL automatically for the backend service.
# Local dev without Docker:
#   DATABASE_URL=postgresql://autopilot:autopilot@localhost:5432/autopilot
DATABASE_URL=
GEMINI_API_KEY=your-gemini-key-here
# EMBEDDING_MODEL=gemini-embedding-001
# EMBEDDING_DIM=1536
# MEMORY_TOP_K=4
# MEMORY_MIN_SCORE=0.75
# MEMORY_DISPLAY_MIN_SCORE=0.2

# ---- Server ----
PORT=8000
NEXT_PUBLIC_API_BASE=http://localhost:8000
