# Copy to .env and fill in. NEVER commit .env or your SSH key.

# ---- Real Phoenix ERP (URL + your team token are on Builder Base) ----
PHOENIX_API_BASE_URL=https://REPLACE-with-the-phoenix-url-from-builder-base
PHOENIX_API_TOKEN=replace-with-your-team-token

# ---- Optional local Docker sandbox cases ----
# Default is 0. Set to 1-5 to have docker compose create that many broken Ubuntu
# containers and point the backends at sandbox Phoenix tickets 7101-7105.
SANDBOX_CASE_COUNT=0
SANDBOX_DOCKER_PRIVILEGED=true
SANDBOX_PHOENIX_API_BASE_URL=http://sandbox-phoenix:9000

# ---- SSH access to the customer VMs ----
# You received 5 per-case keys (case1..5). Copy them into ./keys/ (git-ignored):
#   cp tb-hackathon-ssh/*.pem keys/
# ./keys is mounted read-only at /keys. SSH_PRIVATE_KEY_PATH is tried first; the SSH runner
# also scans SSH_KEY_DIR recursively for the per-VM keys.
SSH_PRIVATE_KEY_PATH=/keys/case1_key.pem
SSH_KEY_DIR=/keys
SSH_USERNAME=azureuser
SSH_CONNECT_TIMEOUT=10
SSH_COMMAND_TIMEOUT=30

# ---- LLM provider: azure (cloud, primary) | openrouter (alt) | local (fallback) ----
LLM_PROVIDER=azure

# Azure OpenAI / Azure AI Foundry. Paste REAL values from important_stuff.txt
# into .env (git-ignored). Keep .env.example secret-free. DEPLOYMENT = your Azure deployment name.
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_KEY=replace-with-your-azure-key
AZURE_OPENAI_API_VERSION=2025-01-01-preview     # match the version shown in your Azure resource
AZURE_OPENAI_DEPLOYMENT=gpt-5.4                 # your *deployment* name (not necessarily the model id)
AZURE_OPENAI_ALLOWED_DEPLOYMENTS=gpt-5.4,gpt-5.4-nano
LLM_MODEL=gpt-5.4

# (Optional) OpenRouter alternative — one key, many models (Claude / Qwen / …)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6
OPENROUTER_ALLOWED_MODELS=

# Local fallback — LM Studio or Ollama (OpenAI-compatible). From Docker use host.docker.internal.
LOCAL_BASE_URL=http://host.docker.internal:1234/v1   # Ollama: http://host.docker.internal:11434/v1
LOCAL_API_KEY=lm-studio
LOCAL_MODEL=

# ---- Shared assets (safety rules + prompts). Mounted read-only at /shared in Docker. ----
SHARED_DIR=/shared          # local dev (no Docker): set to ../shared

# ---- Frontend: which backend the browser calls (8000 = python, 8001 = node) ----
VITE_API_BASE=http://localhost:8000
