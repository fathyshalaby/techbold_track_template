    "@hono/zod-validator": "^0.4.3",
    "@techbold/contracts": "workspace:*",
    "ai": "^4.3.16",
    "better-sqlite3": "^11.9.1",
    "hono": "^4.7.7",
    "ssh2": "^1.16.0",
    "tsx": "^4.19.3",
    "ulid": "^3.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.15.21",
    "@types/ssh2": "^1.15.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  }
