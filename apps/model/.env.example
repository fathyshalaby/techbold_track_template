# Hugging Face token, required for gated/private models.
HF_TOKEN=

# Default European model option.
BASE_MODEL=mistralai/Ministral-3-14B-Instruct-2512

# Optional serving overrides.
ADAPTER_PATH=outputs/adapter
LORA_NAME=msp
PORT=8001

# Optional Apple Silicon MLX local adapter serving.
MLX_MODEL=mlx-community/Qwen2.5-1.5B-Instruct-4bit
MLX_ADAPTER_PATH=outputs/mlx-adapter
MLX_PORT=8011
