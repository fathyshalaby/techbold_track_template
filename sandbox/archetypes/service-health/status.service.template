[Unit]
Description=Sandbox __SERVICE_NAME__ health service
After=network.target

[Service]
Type=simple
User=azureuser
Environment=SERVICE_PORT=__SERVICE_PORT__
Environment=HEALTH_PATH=__HEALTH_PATH__
ExecStart=/usr/bin/python3 /opt/__SERVICE_NAME__/service.py
Restart=on-failure
RestartSec=2

[Install]
WantedBy=multi-user.target
