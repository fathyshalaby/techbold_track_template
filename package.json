{
  "name": "techbold-track-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": ["apps/backend", "apps/dashboard", "packages/contracts"],
  "trustedDependencies": ["better-sqlite3", "ssh2", "cpu-features", "esbuild"],
  "engines": {
    "bun": ">=1.1"
  },
  "scripts": {
    "artifact-guard": "bash scripts/check-artifacts.sh",
    "build": "bun run --filter @techbold/contracts typecheck && bun run --filter techbold-track-dashboard build",
    "check": "bun run lint && bun run typecheck && bun run test && bun run sandbox:test && bun run build && bun run artifact-guard",
    "dev:dashboard": "bun run --filter techbold-track-dashboard dev",
    "dev:backend": "bun run --filter techbold-track-backend dev",
    "dev:frontend": "bun run --filter techbold-track-dashboard dev",
    "start": "bash scripts/start.sh",
    "stop": "bash scripts/stop.sh",
    "restart": "bash scripts/stop.sh && bash scripts/start.sh",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "model": "bash scripts/model-demo.sh",
    "model:all": "bash scripts/model-demo.sh showcase",
    "model:clean": "bash scripts/model-demo.sh clean",
    "model:create": "bash scripts/model-demo.sh train",
    "model:data": "bash scripts/model-demo.sh data",
    "model:doctor": "bash scripts/model-demo.sh doctor",
    "model:prompt": "bash scripts/model-demo.sh prompt",
    "model:serve": "bash scripts/model-demo.sh serve",
    "model:showcase": "bash scripts/model-demo.sh showcase",
    "model:synthetic": "bash scripts/model-demo.sh data",
    "model:train": "bash scripts/model-demo.sh train",
    "model:verify": "bash scripts/model-demo.sh verify",
    "model:vllm": "bash scripts/model-demo.sh vllm",
    "prepare": "husky",
    "sandbox:up": "cd infra/sandbox && bun run up",
    "sandbox:down": "cd infra/sandbox && bun run down",
    "sandbox:reset": "cd infra/sandbox && bun run reset",
    "sandbox:test": "cd infra/sandbox && bun test",
    "test": "bun run --filter @techbold/contracts test && bun run --filter techbold-track-backend test && bun run --filter techbold-track-dashboard test",
    "typecheck": "bun run --filter @techbold/contracts typecheck && bun run --filter techbold-track-backend typecheck && bun run --filter techbold-track-dashboard typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css}": "biome check --write --no-errors-on-unmatched",
    "*.py": "scripts/lint-python.sh"
  }
}
