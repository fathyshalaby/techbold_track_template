{
  "runtime": "codex",
  "model_profile": "balanced",
  "mode": "interactive",
  "granularity": "standard",
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "auto_advance": false,
    "nyquist_validation": true,
    "node_repair": true,
    "node_repair_budget": 2,
    "human_verify_mode": "end-of-phase",
    "tdd_mode": false,
    "use_worktrees": true,
    "code_review": true,
    "code_review_depth": "standard",
    "security_enforcement": false,
    "post_planning_gaps": true,
    "pattern_mapper": true,
    "auto_prune_state": true
  },
  "parallelization": {
    "enabled": true,
    "plan_level": true,
    "task_level": false,
    "skip_checkpoints": true,
    "max_concurrent_agents": 3,
    "min_plans_for_parallel": 2
  },
  "intel": {
    "enabled": true
  },
  "graphify": {
    "enabled": true,
    "auto_update": false
  },
  "hooks": {
    "context_warnings": true,
    "workflow_guard": true
  }
}